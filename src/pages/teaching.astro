---
import BaseLayout from "../layouts/BaseLayout.astro";

const title = "Teaching";
const description = "Courses, programs, and pedagogical work — E145, MS&E 272, MS&E 379, NovoEd, BASES, and Stanford's international entrepreneurship programs.";
---

<BaseLayout title={title} description={description} sideBarActiveItemID="teaching">

  <h1 class="text-3xl w-full font-bold mb-5">Teaching</h1>

  <div class="mb-8 text-lg opacity-80 italic">
    Three Stanford courses, a long-running ITRI partnership, and a 200,000-student MOOC story that turned into a company. Syllabi and teaching cases below are open-sourced — use, adapt, and build on them.
  </div>

  <figure class="mb-12">
    <img
      src="/images/teaching-shenzhen-keynote.webp"
      alt="Chuck Eesley delivering a keynote on entrepreneurship education to a packed bilingual lecture hall"
      class="w-full border border-base-300 rounded"
      loading="eager"
      fetchpriority="high"
    />
  </figure>

  {/* ===========================================================
      CURRENT COURSES
      =========================================================== */}
  <h2 class="text-2xl w-full font-bold mb-2 mt-6">Current courses</h2>

  <article class="mb-10 pb-8 border-b border-base-300">
    <h3 class="font-bold text-xl mb-2">Technology Entrepreneurship — Stanford E145</h3>
    <div class="text-sm opacity-70 mb-3">Stanford Engineering · taught since 2009</div>
    <p class="text-base leading-relaxed mb-3">
      The flagship Stanford technology entrepreneurship course. Project-based introduction to the discipline of building technology ventures — opportunity identification, customer development, team formation, and the institutional context around startups.
    </p>
    <p class="text-base leading-relaxed">
      The online version, recorded for free between 2013 and 2018, reached more than 200,000 students worldwide and seeded the company that later became <a class="link" href="https://novoed.com" target="_blank" rel="noopener noreferrer">NovoEd</a>, acquired by Devonshire Investors / Fidelity.
    </p>
    <figure class="my-5">
      <img
        src="/images/teaching-stvp-vc-charts.webp"
        alt="Chuck Eesley teaching at STVP, presenting venture funding charts"
        class="w-full border border-base-300 rounded"
        loading="lazy"
      />
    </figure>
    <div class="mt-4 text-sm">
      <a class="link" href="https://www.youtube.com/playlist?list=PLF6C0319C607DEDC1" target="_blank" rel="noopener noreferrer">Watch the 27-lecture course on YouTube ↗</a>
    </div>
  </article>

  <article class="mb-10 pb-8 border-b border-base-300">
    <h3 class="font-bold text-xl mb-2">Entrepreneurship Without Borders — MS&E 272</h3>
    <div class="text-sm opacity-70 mb-3">Stanford MS&amp;E · co-taught with Vimbayi Kajese</div>
    <p class="text-base leading-relaxed mb-3">
      Cross-border, cross-institutional view of entrepreneurship. How different countries' institutional environments — capital markets, IP regimes, labor mobility, government industrial policy — shape who can build a high-growth technology venture, and what they actually build.
    </p>
    <p class="text-base leading-relaxed">
      <strong>Recently revised for the agentic AI era:</strong> the course now spends substantial time on what AI agents change about cross-border venture formation — talent geography, customer development at unfamiliar distances, regulatory exposure across jurisdictions, and the new shape of entrepreneurial cognition when the founder is working alongside agents that don't share their institutional intuitions.
    </p>
  </article>

  <article class="mb-10 pb-8 border-b border-base-300">
    <h3 class="font-bold text-xl mb-2">Causal Inference for Entrepreneurship Research — MS&E 379</h3>
    <div class="text-sm opacity-70 mb-3">Stanford MS&amp;E · PhD-level</div>
    <p class="text-base leading-relaxed">
      Doctoral seminar on quasi-experimental methods for empirical entrepreneurship and strategy research — difference-in-differences, regression discontinuity, instrumental variables, synthetic control, and the growing toolkit of LLM-based methods for policy and regulatory corpora.
    </p>
  </article>

  {/* ===========================================================
      INTERNATIONAL & EXECUTIVE
      =========================================================== */}
  <h2 class="text-2xl w-full font-bold mb-2 mt-12">International &amp; executive programs</h2>

  <article class="mb-10 pb-8 border-b border-base-300">
    <h3 class="font-bold text-xl mb-2">ITRI–Stanford Platform — Advancing Technology Ventures Program</h3>
    <div class="text-sm opacity-70 mb-3">Academic Director · 2013–present</div>
    <p class="text-base leading-relaxed">
      Twelve-week program developed in partnership with Taiwan's Industrial Technology Research Institute (ITRI), the Department of Industrial Technology (DOIT), and the Ministry of Economic Affairs (MOEA). Mentors deep-tech startup teams on commercial development and global market entry.
    </p>
    <figure class="my-5">
      <img
        src="/images/teaching-stanford-history.webp"
        alt="Chuck Eesley delivering a session on the institutional history of Stanford entrepreneurship"
        class="w-full border border-base-300 rounded"
        loading="lazy"
      />
    </figure>
  </article>

  <article class="mb-10 pb-8 border-b border-base-300">
    <h3 class="font-bold text-xl mb-2">Stanford BOSP Shenzhen Global Seminar</h3>
    <div class="text-sm opacity-70 mb-3">Faculty Director · August 2026</div>
    <p class="text-base leading-relaxed">
      Stanford Bing Overseas Studies Program seminar based at InnoX Academy in Shenzhen, examining China's innovation ecosystem from inside one of its most active corridors.
    </p>
  </article>

  <article class="mb-10 pb-8 border-b border-base-300">
    <h3 class="font-bold text-xl mb-2">The Chinese University of Hong Kong — Faculty in Residence</h3>
    <div class="text-sm opacity-70 mb-3">Aug–Dec 2023 · via Stanford BOSP</div>
    <p class="text-base leading-relaxed">
      Semester in residence at CUHK through Stanford's Bing Overseas Studies Program.
    </p>
  </article>

  {/* ===========================================================
      MENTORSHIP & STUDENT PROGRAMS
      =========================================================== */}
  <h2 class="text-2xl w-full font-bold mb-2 mt-12">Mentorship &amp; student programs</h2>

  <article class="mb-10 pb-8 border-b border-base-300">
    <h3 class="font-bold text-xl mb-2">BASES — Stanford's largest entrepreneurship student organization</h3>
    <div class="text-sm opacity-70 mb-3">Faculty Advisor</div>
    <p class="text-base leading-relaxed">
      Faculty advisor to BASES (Business Association of Stanford Engineering Students), which runs Stanford's flagship undergraduate entrepreneurship competitions, mentorship programs, and the student-run E-Bootcamp.
    </p>
  </article>

  <article class="mb-10 pb-8 border-b border-base-300">
    <h3 class="font-bold text-xl mb-2">PhD advising</h3>
    <p class="text-base leading-relaxed">
      I advise PhD students in MS&amp;E whose work intersects entrepreneurship, institutional design, industrial policy, AI's effects on innovation, or the global political economy of technology. <a class="link" href="/prospective-students">For prospective applicants →</a>
    </p>
  </article>

  <article class="mb-10 pb-8 border-b border-base-300">
    <h3 class="font-bold text-xl mb-2">Undergraduate research</h3>
    <p class="text-base leading-relaxed">
      I hire undergraduate research assistants primarily through the <a class="link" href="https://msande.stanford.edu/research-impact/mse-student-research/research-experience-undergraduates" target="_blank" rel="noopener noreferrer">MS&amp;E REU program</a>, the <a class="link" href="https://kingcenter.stanford.edu/opportunities/undergraduate-students" target="_blank" rel="noopener noreferrer">King Center on Global Development</a>, and the <a class="link" href="https://sustainability-accelerator.stanford.edu/get-involved/ecoramp-undergraduate-research-opportunities" target="_blank" rel="noopener noreferrer">Doerr School Sustainability Accelerator (EcoRamp)</a>. <a class="link" href="/advising">Former RAs and lab alumni →</a>
    </p>
  </article>

  {/* ===========================================================
      OPEN MATERIALS — SYLLABI, MINI-CASES, TALKS ON TEACHING
      =========================================================== */}
  <h2 class="text-2xl w-full font-bold mb-2 mt-12">Open materials</h2>
  <div class="mb-8 text-base opacity-70 italic">
    Syllabi, teaching cases, and talks on pedagogy &mdash; open-sourced for any instructor who wants to use or adapt them. Attribution appreciated; no permission required.
  </div>

  {/* SYLLABI */}
  <h3 class="font-bold text-xl mb-3 mt-6">Syllabi</h3>
  <ul class="list-disc list-inside text-base space-y-2 mb-10 leading-relaxed">
    <li>
      <strong>E145 &mdash; Technology Entrepreneurship.</strong>
      <a class="link" href="#" target="_blank">[ Add syllabus link ]</a>
    </li>
    <li>
      <strong>MS&amp;E 272 &mdash; Entrepreneurship Without Borders</strong> (revised for the agentic AI era).
      <a class="link" href="#" target="_blank">[ Add syllabus link ]</a>
    </li>
    <li>
      <strong>MS&amp;E 379 &mdash; Causal Inference for Entrepreneurship Research.</strong>
      <a class="link" href="#" target="_blank">[ Add syllabus link ]</a>
    </li>
  </ul>

  {/* MINI-CASES */}
  <h3 class="font-bold text-xl mb-3 mt-6">Mini-cases</h3>
  <div class="mb-4 text-base opacity-80 leading-relaxed">
    Short teaching cases written for E145 and MS&amp;E 272. Each case foregrounds a specific institutional or strategic decision rather than a comprehensive company history &mdash; designed for 20&ndash;30 minutes of in-class discussion.
  </div>

  <div class="grid md:grid-cols-3 gap-4 mb-10">

    <article class="border border-base-300 rounded-lg p-5 bg-base-200/40">
      <h4 class="font-bold text-lg mb-2">Labayh</h4>
      <p class="text-sm leading-relaxed mb-3 opacity-90">
        [ 1&ndash;2 sentence framing of the case &mdash; what's at stake, why it's a useful teaching case ]
      </p>
      <a class="link text-sm" href="#" target="_blank">[ Add case link ]</a>
    </article>

    <article class="border border-base-300 rounded-lg p-5 bg-base-200/40">
      <h4 class="font-bold text-lg mb-2">Cashea</h4>
      <p class="text-sm leading-relaxed mb-3 opacity-90">
        [ 1&ndash;2 sentence framing of the case &mdash; what's at stake, why it's a useful teaching case ]
      </p>
      <a class="link text-sm" href="#" target="_blank">[ Add case link ]</a>
    </article>

    <article class="border border-base-300 rounded-lg p-5 bg-base-200/40">
      <h4 class="font-bold text-lg mb-2">Climate.ai</h4>
      <p class="text-sm leading-relaxed mb-3 opacity-90">
        [ 1&ndash;2 sentence framing of the case &mdash; what's at stake, why it's a useful teaching case ]
      </p>
      <a class="link text-sm" href="#" target="_blank">[ Add case link ]</a>
    </article>

  </div>

  {/* TALKS ON PEDAGOGY */}
  <h3 class="font-bold text-xl mb-3 mt-6">Talks on teaching</h3>
  <ul class="list-disc list-inside text-base space-y-3 mb-10 leading-relaxed">
    <li>
      <strong>Teaching Entrepreneurship in the AI Era.</strong> STVP event at Google Huddle, hosted by Emily Ma. On how the agentic-AI moment changes what we teach in entrepreneurship courses &mdash; what stays, what gets replaced, and what becomes newly important.
      <a class="link text-sm" href="#" target="_blank">[ Add slides or recording link ]</a>
    </li>
    <li>
      <strong>The Future of Entrepreneurship Education at STVP.</strong> MS&amp;E 25th Anniversary, May 2025. Opening vision and closing reflections, bookending a fireside chat between Steve Blank and Riitta Katila. <a class="link text-sm" href="/talks#teaching">Watch on Talks &amp; Media &rarr;</a>
    </li>
  </ul>

  {/* ===========================================================
      AWARDS & RECOGNITION
      =========================================================== */}
  <h2 class="text-2xl w-full font-bold mb-2 mt-12">Teaching honors</h2>

  <ul class="list-disc list-inside text-base space-y-2 mt-4 mb-10 opacity-90">
    <li>Stanford Teagle Fellow in Liberal Education (2022)</li>
    <li>Undergraduate Teaching Award, Stanford MS&amp;E (2017)</li>
    <li>Richard Schulze Inaugural Distinguished Professorship Award (2015)</li>
  </ul>

  {/* ===========================================================
      FURTHER
      =========================================================== */}
  <div class="border-t border-base-300 mt-12 pt-6 text-base leading-relaxed">
    Talks about teaching, learning at scale, and the STVP pedagogical model are on the <a class="link" href="/talks#teaching">Talks &amp; Media page</a>. Curated course readings are on the <a class="link" href="/reading">Reading list</a>.
  </div>

</BaseLayout>
