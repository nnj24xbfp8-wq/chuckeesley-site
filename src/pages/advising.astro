---

<BaseLayout title={title} description={description} sideBarActiveItemID="advising">

  <div class="mb-5">
    <div class="text-3xl w-full font-bold">Advising</div>
  </div>

  <div class="mb-10 text-lg leading-relaxed">
    <p class="mb-4">
      I advise PhD students in Stanford MS&amp;E whose work intersects entrepreneurship, institutional design, industrial policy, AI's effects on innovation, or the global political economy of technology. The list below covers students and postdocs I've worked with directly. For prospective students considering applying, see the <a class="link" href="/prospective-students">MS&amp;E PhD page</a>.
    </p>
  </div>

  {/* CURRENT PhD STUDENTS */}
  <div class="text-2xl w-full font-bold mt-10 mb-2">Current PhD students</div>
  <div class="mb-6 text-base opacity-70 italic">
    {currentPhD.length} students currently advising or co-advising.
  </div>
  <ul class="list-none p-0">
    {currentPhD.map((s) => (
      <li class="mb-7 pb-6 border-b border-base-300">
        <div class="font-bold text-lg leading-snug">
          {s.link ? (
            <a href={s.link} target="_blank" rel="noopener noreferrer" class="link">{s.name}</a>
          ) : (
            <span>{s.name}</span>
          )}
          {s.coAdvisor && (
            <span class="font-normal italic text-sm opacity-70"> · co-advised with {s.coAdvisor}</span>
          )}
        </div>
        <div class="text-sm opacity-70 mt-1">{s.years} · {s.expected}</div>
        <p class="text-base mt-2 italic">{s.thesis}</p>
      </li>
    ))}
  </ul>

  {/* POSTDOCTORAL RESEARCHERS — INCOMING */}
  {incomingPostdocs.length > 0 && (
    <>
      <div class="text-2xl w-full font-bold mt-12 mb-2">Incoming postdoctoral researchers</div>
      <ul class="list-none p-0">
        {incomingPostdocs.map((p) => (
          <li class="mb-7 pb-6 border-b border-base-300">
            <div class="font-bold text-lg leading-snug">
              {p.link ? (
                <a href={p.link} target="_blank" rel="noopener noreferrer" class="link">{p.name}</a>
              ) : (
                <span>{p.name}</span>
              )}
            </div>
            <div class="text-sm opacity-70 mt-1">{p.role} · {p.years}</div>
            {p.nowAt && <p class="text-base mt-2">{p.nowAt}</p>}
          </li>
        ))}
      </ul>
    </>
  )}

  {/* POSTDOCTORAL RESEARCHERS — FORMER */}
  {formerPostdocs.length > 0 && (
    <>
      <div class="text-2xl w-full font-bold mt-12 mb-2">Former postdoctoral researchers</div>
      <ul class="list-none p-0">
        {formerPostdocs.map((p) => (
          <li class="mb-7 pb-6 border-b border-base-300">
            <div class="font-bold text-lg leading-snug">
              {p.link ? (
                <a href={p.link} target="_blank" rel="noopener noreferrer" class="link">{p.name}</a>
              ) : (
                <span>{p.name}</span>
              )}
            </div>
            <div class="text-sm opacity-70 mt-1">{p.role} · {p.years}</div>
            {p.nowAt && <p class="text-base mt-2">{p.nowAt}</p>}
          </li>
        ))}
      </ul>
    </>
  )}

  {/* FORMER PhD STUDENTS */}
  <div class="text-2xl w-full font-bold mt-12 mb-2">Former PhD students</div>
  <div class="mb-6 text-base opacity-70 italic">
    {formerPhD.length} students who completed their doctoral work under my advisement or co-advisement, in reverse chronological order by graduation year.
  </div>
  <ul class="list-none p-0">
    {formerPhD.map((s) => (
      <li class="mb-7 pb-6 border-b border-base-300">
        <div class="font-bold text-lg leading-snug">
          {s.link ? (
            <a href={s.link} target="_blank" rel="noopener noreferrer" class="link">{s.name}</a>
          ) : (
            <span>{s.name}</span>
          )}
          {s.coAdvisor && (
            <span class="font-normal italic text-sm opacity-70"> · co-advised with {s.coAdvisor}</span>
          )}
        </div>
        <div class="text-sm opacity-70 mt-1">
          {s.years} · {s.graduated === "ABD" ? "ABD (did not complete dissertation)" : `Graduated ${s.graduated}`}
        </div>
        <p class="text-base mt-2 italic">{s.thesis}</p>
        {s.nowAt && <p class="text-sm mt-2"><span class="opacity-70">Now:</span> {s.nowAt}</p>}
      </li>
    ))}
  </ul>

  {/* CURRENT RESEARCH ASSISTANTS */}
  {currentRAs.length > 0 && (
    <>
      <div class="text-2xl w-full font-bold mt-12 mb-2">Current research assistants</div>
      <div class="mb-6 text-base opacity-70 italic">
        Students currently working on Eesley Lab research projects.
      </div>
      <ul class="list-none p-0 grid sm:grid-cols-2 gap-x-6">
        {currentRAs.map((r) => (
          <li class="mb-4 pb-3 border-b border-base-300">
            <div class="font-bold text-base leading-snug">
              {r.link ? (
                <a href={r.link} target="_blank" rel="noopener noreferrer" class="link">{r.name}</a>
              ) : (
                <span>{r.name}</span>
              )}
            </div>
            {r.note && <p class="text-sm opacity-80 mt-1">{r.note}</p>}
          </li>
        ))}
      </ul>
    </>
  )}

  {/* FORMER RESEARCH ASSISTANTS */}
  {formerRAs.length > 0 && (
    <>
      <div class="text-2xl w-full font-bold mt-12 mb-2">Former research assistants</div>
      <ul class="list-none p-0">
        {formerRAs.map((r) => (
          <li class="mb-5 pb-4 border-b border-base-300">
            <div class="font-bold text-base leading-snug">
              {r.link ? (
                <a href={r.link} target="_blank" rel="noopener noreferrer" class="link">{r.name}</a>
              ) : (
                <span>{r.name}</span>
              )}
            </div>
            {r.note && <p class="text-sm opacity-80 mt-1">{r.note}</p>}
          </li>
        ))}
      </ul>
    </>
  )}

  {/* ACKNOWLEDGMENT */}
  <div class="border-t border-base-300 mt-16 pt-6 text-sm opacity-70 italic">
    Pulled from my Stanford School of Engineering CV (last updated January 2026), with current affiliations verified as of May 2026. Predoctoral researchers and external collaborators not yet listed — those additions are coming.
  </div>

</BaseLayout>
