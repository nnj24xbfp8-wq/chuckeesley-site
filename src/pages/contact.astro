---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Contact" sideBarActiveItemID="contact">

  <div>
    <h1 class="text-3xl w-full font-bold mb-2">Contact</h1>
    <div class="mb-8 text-lg opacity-80">For speaking inquiries, media requests, and research collaborations. Journalists on deadline can <a href="mailto:chuck@chuckeesley.com" class="link">email me directly</a>.</div>
  </div>

  <div class="mb-8 p-5 border border-base-300 rounded-lg bg-base-200/40 max-w-2xl">
    <div class="font-bold text-lg mb-2">Before you fill this out</div>
    <ul class="list-disc list-inside text-base space-y-1 opacity-90">
      <li>Prospective PhD applicants &mdash; please read the <a class="link" href="/prospective-students">prospective students page</a> first. I don't pre-screen applications.</li>
      <li>Undergraduate research / RA inquiries &mdash; see the <a class="link" href="/advising">advising page</a>; I hire through MS&amp;E REU, the King Center, and EcoRamp.</li>
      <li>Board, advisory, or investment inquiries &mdash; brief email to <a class="link" href="mailto:chuck@chuckeesley.com">chuck@chuckeesley.com</a> is best.</li>
      <li>Speaking, media, and research collaborations &mdash; the form below is the right channel. Event organizers can grab bios &amp; headshot from the <a class="link" href="/press-kit">press kit</a>.</li>
    </ul>
  </div>

<form
    action="https://formspree.io/f/mkoyjnla"
    method="POST"
    data-astro-reload
    class="grid gap-4 mb-10 max-w-2xl"
>
    <div>
      <label for="name" class="label">
        <span class="label-text text-base">Name</span>
      </label>
      <input
        type="text"
        id="name"
        name="name"
        required
        class="input input-bordered w-full"
      />
    </div>

    <div>
      <label for="email" class="label">
        <span class="label-text text-base">Email</span>
      </label>
      <input
        type="email"
        id="email"
        name="email"
        required
        class="input input-bordered w-full"
      />
    </div>

    <div>
      <label for="affiliation" class="label">
        <span class="label-text text-base">Affiliation / Organization</span>
      </label>
      <input
        type="text"
        id="affiliation"
        name="affiliation"
        class="input input-bordered w-full"
      />
    </div>

    <div>
      <label for="inquiry_type" class="label">
        <span class="label-text text-base">Inquiry type</span>
      </label>
      <select
        id="inquiry_type"
        name="inquiry_type"
        required
        class="select select-bordered w-full"
      >
        <option value="" disabled selected>Select one</option>
        <option value="Speaking">Speaking</option>
        <option value="Media / Press">Media / Press</option>
        <option value="Research collaboration">Research collaboration</option>
        <option value="Other">Other</option>
      </select>
    </div>

    <div>
      <label for="event_details" class="label">
        <span class="label-text text-base">If speaking inquiry: date, location, audience</span>
      </label>
      <input
        type="text"
        id="event_details"
        name="event_details"
        placeholder="e.g., June 12 in Chicago, 200 senior executives"
        class="input input-bordered w-full"
      />
    </div>

    <div>
      <label for="message" class="label">
        <span class="label-text text-base">Message</span>
      </label>
      <textarea
        id="message"
        name="message"
        required
        rows="6"
        class="textarea textarea-bordered w-full"
      ></textarea>
    </div>

    <input type="hidden" name="_subject" value="New website inquiry" />
    <div class="hidden" aria-hidden="true">
      <label>Don't fill this out if you're human: <input type="text" name="_gotcha" tabindex="-1" autocomplete="off" /></label>
    </div>

    <div>
      <button type="submit" class="btn btn-primary">Send</button>
    </div>
  </form>

</BaseLayout>
