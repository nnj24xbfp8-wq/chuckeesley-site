---
import BaseLayout from "../../layouts/BaseLayout.astro";
import HorizontalCard from "../../components/HorizontalCard.astro";
import { getCollection } from "astro:content";
import createSlug from "../../lib/createSlug";
import dayjs from "dayjs";

// The Writing index merges Substack posts (pulled from the publication's RSS
// feed at build time) with any locally-authored posts in the blog content
// collection. Substack wins on duplicate titles. Falls back to local-only
// if the feed fetch fails.

type Essay = {
  title: string;
  url: string;
  description: string;
  pubDate: Date;
  target: "_blank" | "_self";
  badge?: string;
  tags?: string[];
};

export async function getStaticPaths({ paginate }) {
  // Inline Substack fetch — getStaticPaths runs in an isolated scope and
  // cannot reach module-level helpers or constants, so we keep them here.
  const SUBSTACK_FEED = "https://ceesley.substack.com/feed";
  const fetchSubstack = async (): Promise<Essay[]> => {
    try {
      const res = await fetch(SUBSTACK_FEED, {
        headers: { "User-Agent": "chuckeesley.com" },
      });
      if (!res.ok) return [];
      const xml = await res.text();
      const items = xml.match(/<item>[\s\S]*?<\/item>/g) ?? [];
      const pick = (block: string, tag: string) => {
        const m = block.match(new RegExp(`<${tag}>([\\s\\S]*?)<\\/${tag}>`));
        if (!m) return "";
        return m[1].replace(/^<!\[CDATA\[/, "").replace(/\]\]>$/, "").trim();
      };
      return items.map((item) => ({
        title: pick(item, "title"),
        url: pick(item, "link"),
        description: pick(item, "description").replace(/<[^>]+>/g, "").trim(),
        pubDate: new Date(pick(item, "pubDate")),
        target: "_blank" as const,
        badge: "SUBSTACK",
      }));
    } catch (err) {
      console.warn("[blog index] Substack RSS fetch failed:", err);
      return [];
    }
  };
  const substack = await fetchSubstack();
  const local = (await getCollection("blog")).map<Essay>((post) => ({
    title: post.data.title,
    url: "/blog/" + createSlug(post.data.title, post.slug),
    description: post.data.description,
    pubDate: new Date(post.data.pubDate),
    target: "_self",
    badge: post.data.badge,
    tags: post.data.tags,
  }));

  // De-duplicate by normalized title; Substack version wins.
  const seen = new Set<string>();
  const combined: Essay[] = [];
  for (const e of [...substack, ...local]) {
    const key = e.title.toLowerCase().replace(/[^a-z0-9]/g, "").slice(0, 60);
    if (seen.has(key)) continue;
    seen.add(key);
    combined.push(e);
  }
  combined.sort((a, b) => b.pubDate.valueOf() - a.pubDate.valueOf());

  return paginate(combined, { pageSize: 10 });
}

const { page } = Astro.props;
---

<BaseLayout title="Writing" sideBarActiveItemID="blog">
  <div class="mb-5">
    <div class="text-3xl w-full font-bold">Writing</div>
  </div>

  <div class="mb-8 text-lg opacity-80">
    Long-form essays on entrepreneurship, institutions, and the global political economy of technology &mdash; most published first on the <a class="link" href="https://newsletter.chuckeesley.com">newsletter</a> at newsletter.chuckeesley.com. New posts arrive roughly monthly.
  </div>

  <div class="mb-10 flex flex-wrap gap-3">
    <a
      href="https://newsletter.chuckeesley.com/subscribe"
      class="btn btn-primary"
    >
      Subscribe to the newsletter
    </a>
    <a
      href="https://newsletter.chuckeesley.com/feed"
      target="_blank"
      rel="noopener noreferrer"
      class="btn btn-outline"
    >
      RSS feed
    </a>
  </div>

  {
    page.data.length === 0 ? (
      <div class="bg-base-200 border-l-4 border-secondary w-full p-4 min-w-full">
        <p class="font-bold">Sorry!</p>
        <p>There are no posts to show at the moment. Check back later!</p>
      </div>
    ) : (
      <ul>
        {page.data.map((essay) => (
          <>
            <HorizontalCard
              title={essay.title}
              desc={`${dayjs(essay.pubDate).format("MMM D, YYYY")} · ${essay.description}`}
              url={essay.url}
              target={essay.target}
              badge={essay.badge}
              tags={essay.tags}
            />
            <div class="divider my-0" />
          </>
        ))}
      </ul>
    )
  }

  <div class="flex justify-between">
    {
      page.url.prev ? (
        <a href={page.url.prev} class="btn btn-ghost my-10 mx-5">
          {" "}
          <svg
            class="h-6 w-6 fill-current md:h-8 md:w-8"
            xmlns="http://www.w3.org/2000/svg"
            width="24"
            height="24"
            viewBox="0 0 24 24"
          >
            <path d="M15.41,16.58L10.83,12L15.41,7.41L14,6L8,12L14,18L15.41,16.58Z" />
          </svg>{" "}
          Recent posts
        </a>
      ) : (
        <div />
      )
    }
    {
      page.url.next ? (
        <a href={page.url.next} class="btn btn-ghost my-10 mx-5">
          Older Posts{" "}
          <svg
            class="h-6 w-6 fill-current md:h-8 md:w-8"
            xmlns="http://www.w3.org/2000/svg"
            width="24"
            height="24"
            viewBox="0 0 24 24"
          >
            {" "}
            <path d="M8.59,16.58L13.17,12L8.59,7.41L10,6L16,12L10,18L8.59,16.58Z" />
          </svg>
        </a>
      ) : (
        <div />
      )
    }
  </div>
</BaseLayout>
