---
import BaseLayout from "../layouts/BaseLayout.astro";
import HorizontalCard from "../components/HorizontalCard.astro";
import { getCollection } from "astro:content";
import createSlug from "../lib/createSlug";
import dayjs from "dayjs";

// "Latest essays" is pulled from Substack RSS at build time.
// If the fetch fails, we fall back to the local blog content collection.
const SUBSTACK_FEED = "https://ceesley.substack.com/feed";

type Essay = {
  title: string;
  url: string;
  description: string;
  pubDate: Date;
  target: "_blank" | "_self";
};

async function fetchSubstackEssays(): Promise<Essay[]> {
  try {
    const res = await fetch(SUBSTACK_FEED, {
      headers: { "User-Agent": "chuckeesley.com" },
    });
    if (!res.ok) return [];
    const xml = await res.text();
    const items = xml.match(/<item>[\s\S]*?<\/item>/g) ?? [];
    const pick = (block: string, tag: string) => {
      const m = block.match(new RegExp(`<${tag}>([\\s\\S]*?)<\\/${tag}>`));
      if (!m) return "";
      return m[1].replace(/^<!\[CDATA\[/, "").replace(/\]\]>$/, "").trim();
    };
    return items.slice(0, 5).map((item) => ({
      title: pick(item, "title"),
      url: pick(item, "link"),
      description: pick(item, "description").replace(/<[^>]+>/g, "").trim(),
      pubDate: new Date(pick(item, "pubDate")),
      target: "_blank" as const,
    }));
  } catch (err) {
    console.warn("[index] Substack RSS fetch failed:", err);
    return [];
  }
}

let essays = await fetchSubstackEssays();
if (essays.length === 0) {
  const posts = (await getCollection("blog")).sort(
    (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
  );
  essays = posts.slice(0, 5).map((post) => ({
    title: post.data.title,
    url: "/blog/" + createSlug(post.data.title, post.slug),
    description: post.data.description,
    pubDate: post.data.pubDate,
    target: "_self" as const,
  }));
}
---

<BaseLayout sideBarActiveItemID="home" image="/og-home.webp">
<div class="pb-12 mt-5">
    <h1 class="text-5xl font-bold">Chuck Eesley</h1>
    <div class="text-3xl py-3 font-bold">Professor of Management Science & Engineering, Stanford University</div>
    <div class="text-xl py-1 italic opacity-80">The institutional environment around founders matters more than we usually admit. I study how — and why.</div>
    <div class="py-4">
      <p class="text-lg">
        I am a Professor of Management Science & Engineering at <a class="link" href="https://profiles.stanford.edu/charles-eesley" target="_blank" rel="noopener noreferrer">Stanford University</a> and Co-Director for International Entrepreneurship at the <b>Stanford Technology Ventures Program (STVP)</b>. My research examines how institutional environments, industrial policy, and platform design shape entrepreneurial outcomes — with particular focus on the United States, China, and emerging markets. Through STVP's global programs I have taught and run field research across six continents.
      </p>
    </div>
    <div class="mt-8">
      <a class="btn" href="https://substack.com/@ceesley" target="_blank">Read the Substack</a>
      <a class="btn btn-outline ml-5" href="https://profiles.stanford.edu/charles-eesley" target="_blank" rel="noopener noreferrer">Stanford profile ↗</a>
      <a href="/services" class="btn btn-outline ml-5">Speaking inquiries</a>
    </div>
  </div>

  {/* =========================================================
      ENGINEERING IMPACT — BY THE NUMBERS
      ========================================================= */}
  <section class="mb-14 border-y border-base-300 py-8">
    <div class="text-xs uppercase tracking-[0.18em] opacity-70 mb-6">Engineering impact, by the numbers</div>
    <div class="grid grid-cols-2 md:grid-cols-4 gap-6 md:gap-8">
      <div>
        <div class="text-3xl md:text-4xl font-bold font-display leading-tight">200,000+</div>
        <div class="text-sm mt-2 opacity-80 leading-snug">students reached through Stanford E145 and the global MOOC</div>
      </div>
      <div>
        <div class="text-3xl md:text-4xl font-bold font-display leading-tight">$6T+</div>
        <div class="text-sm mt-2 opacity-80 leading-snug">in alumni-founded company revenue documented across MIT, Stanford, and UVA</div>
      </div>
      <div>
        <div class="text-3xl md:text-4xl font-bold font-display leading-tight">6,862+</div>
        <div class="text-sm mt-2 opacity-80 leading-snug">citations across management, economics, and information systems · <a class="link" href="https://scholar.google.com/citations?user=ENeJ_gkAAAAJ&hl=en" target="_blank" rel="noopener noreferrer">Google Scholar ↗</a></div>
      </div>
      <div>
        <div class="text-3xl md:text-4xl font-bold font-display leading-tight">4</div>
        <div class="text-sm mt-2 opacity-80 leading-snug">research universities using the alumni-survey methodology (MIT, Stanford, UVA, Tsinghua) — pioneered with Edward B. Roberts</div>
      </div>
    </div>
  </section>

  {/* =========================================================
      FEATURED IN — MEDIA / PUBLICATIONS
      ========================================================= */}
  <section class="mb-14">
    <div class="text-xs uppercase tracking-[0.18em] opacity-70 mb-4 text-center md:text-left">Featured in</div>
    <div class="flex flex-wrap gap-x-6 gap-y-3 text-base md:text-lg font-display italic opacity-90 justify-center md:justify-start items-baseline">
      <span>Nature</span>
      <span class="opacity-40">·</span>
      <span>Bloomberg</span>
      <span class="opacity-40">·</span>
      <span>Stanford Report</span>
      <span class="opacity-40">·</span>
      <span>Stanford Engineering</span>
      <span class="opacity-40">·</span>
      <span>Forbes</span>
      <span class="opacity-40">·</span>
      <span>MIT News</span>
      <span class="opacity-40">·</span>
      <span>Strategic Management Journal</span>
    </div>
    <div class="mt-4 text-sm opacity-70">
      <a class="link" href="/press">Full press &amp; media coverage →</a>
    </div>
  </section>

  <h2 class="text-3xl w-full font-bold mb-2">Featured research</h2>

<HorizontalCard
  title="The Algorithmic Financing of Online Misinformation"
  desc="Published in Nature. Tracing how programmatic advertising routes money to misinformation websites — and what advertisers can do about it. With Wajeeha Ahmad, Ananya Sen, and Erik Brynjolfsson."
  url="https://doi.org/10.1038/s41586-024-07404-1"
  badge="NATURE"
  target="_blank"
/>
<div class="divider my-0"></div>
<HorizontalCard
  title="When External Shocks Attract Capital: Export Controls and Venture Capital Allocation in China"
  desc="U.S. export controls were meant to slow China's semiconductor sector. Instead, Chinese semiconductor startups received 6 percentage points more financing and raised about 12% more capital than comparable peers. With Yikai Cao, Wanru Deng, and Guankai Zhai."
  url="/research/export-controls-vc"
  badge="NEW"
  target="_self"
/>
<div class="divider my-0"></div>
<HorizontalCard
  title="Industrial Policy Reshapes Venture Capital in Climate Tech"
  desc="The IRA selectively redirected venture capital toward climate-aligned technologies. We build a Policy Credibility Index showing institutional design quality matters as much as incentive size. With Yikai Cao, Rishee Jain, and Dinesh Moorjani."
  url="/research/ira-cleantech"
  badge="NEW"
  target="_self"
/>
<div class="divider my-0"></div>
<HorizontalCard
  title="Subsidy Design Without Capability Screening (China battery subsidies)"
  desc="China's massive battery subsidies attract more firms — but the marginal entrants are short-lived, low-commitment participants who never build productive capacity. Subsidies without capability screening produce participation without commitment. With Guankai Zhai."
  url="/research/battery-subsidies"
  badge="NEW"
  target="_self"
/>

  <h2 class="text-3xl w-full font-bold mb-5 mt-10">Latest essays</h2>
  {
    essays.map((essay) => (
      <>
        <HorizontalCard
          title={essay.title}
          desc={`${dayjs(essay.pubDate).format("MMM D, YYYY")} · ${essay.description}`}
          url={essay.url}
          target={essay.target}
          badge="SUBSTACK"
        />
        <div class="divider my-0" />
      </>
    ))
  }
</BaseLayout>
