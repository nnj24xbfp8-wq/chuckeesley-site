---
import BaseLayout from "../layouts/BaseLayout.astro";
import HorizontalCard from "../components/HorizontalCard.astro";
import { getCollection } from "astro:content";
import createSlug from "../lib/createSlug"

const posts = (await getCollection("blog")).sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
const last_posts = posts.slice(0, 3);
---

<BaseLayout sideBarActiveItemID="home" image="/social_img.webp">
<div class="pb-12 mt-5">
    <div class="text-5xl font-bold">Chuck Eesley</div>
    <div class="text-3xl py-3 font-bold">Professor of Management Science & Engineering, Stanford University</div>
    <div class="text-xl py-1 italic opacity-80">The institutional environment around founders matters more than we usually admit. I study how, and why.</div>
    <div class="py-4">
      <p class="text-lg">
        I am a Professor of Management Science & Engineering at Stanford University and Co-Director for International Entrepreneurship at the <b>Stanford Technology Ventures Program (STVP)</b>. My research examines how institutional environments, industrial policy, and platform design shape entrepreneurial outcomes — with particular focus on the United States, China, and emerging markets. Through STVP's global programs I have taught and run field research across six continents.
      </p>
    </div>
    <div class="mt-8">
      <a class="btn" href="https://substack.com/@ceesley" target="_blank">Read the Substack</a>
      <a href="/contact" class="btn btn-outline ml-5">Speaking inquiries</a>
    </div>
  </div>

  <div>
    <div class="text-3xl w-full font-bold mb-2">Featured research</div>
  </div>

  <HorizontalCard
    title="The Algorithmic Financing of Online Misinformation"
    img="/post_img.webp"
    desc="Published in Nature. Tracing how programmatic advertising routes money to misinformation websites — and what advertisers can do about it. With Wajeeha Ahmad, Ananya Sen, and Erik Brynjolfsson."
    url="/projects"
    badge="NATURE"
  />
  <div class="divider my-0"></div>
  <HorizontalCard
    title="The Economic Impact of Stanford Alumni-Founded Companies"
    img="/post_img.webp"
    desc="Decades of data showing how a single university produces ventures whose annual revenues rival the GDP of a top-ten global economy. With William F. Miller."
    url="/projects"
  />
  <div class="divider my-0"></div>
  <HorizontalCard
    title="Export Controls and the Global Reallocation of Venture Capital"
    img="/post_img.webp"
    desc="How US export controls are reshaping where venture capital flows globally. With Yikai Cao."
    url="/projects"
    badge="NEW"
  />

  <div>
    <div class="text-3xl w-full font-bold mb-5 mt-10">Latest essays</div>
  </div>
  {
    last_posts.map((post) => (
      <>
        <HorizontalCard
          title={post.data.title}
          img={post.data.heroImage}
          desc={post.data.description}
          url={"/blog/" + createSlug(post.data.title, post.slug)}
          target="_self"
          badge={post.data.badge}
        />
        <div class="divider my-0" />
      </>
    ))
  }
</BaseLayout>
